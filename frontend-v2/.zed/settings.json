{
  "language_servers": ["!eslint", "!typescript-language-server", "..."],
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "./node_modules/@biomejs/biome/bin/biome",
          "arguments": [
            "check",
            "--write",
            "--unsafe",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "./node_modules/@biomejs/biome/bin/biome",
          "arguments": [
            "check",
            "--write",
            "--unsafe",
            "--stdin-file-path",
            "{buffer_path}"
          ]
        }
      }
    }
  }
}
